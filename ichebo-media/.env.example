# Ichebo Media (mediad) — Environment Variables
#
# In production this file is deployed to /etc/ichebo/media.env, referenced
# by deploy/mediad.service (EnvironmentFile=/etc/ichebo/media.env).
# Never commit the real file to version control.
#
# IMPORTANT: every variable below currently falls back to an empty string if
# unset, with no startup validation — the service will start and appear
# healthy even if S3 or the Django webhook are misconfigured. Set every
# variable in this file explicitly before going live; do not rely on defaults
# for anything beyond MEDIA_PORT, MEDIA_FFMPEG_PATH, MEDIA_TEMP_DIR, and
# MEDIA_WORKER_COUNT, which are genuinely safe to leave unset.

# ── Server ───────────────────────────────────────────────────────────────────

# Port mediad listens on. Default: 8090
MEDIA_PORT=8090

# Path to the ffmpeg binary. Default: ffmpeg (resolved via PATH)
MEDIA_FFMPEG_PATH=ffmpeg

# Scratch directory for in-progress uploads/transcodes. Default: /tmp/ichebo-media
MEDIA_TEMP_DIR=/tmp/ichebo-media

# Number of concurrent transcode workers. Default: min(4, CPU cores - 1)
# Leave unset unless you have a specific reason to override the default.
MEDIA_WORKER_COUNT=

# ── Object Storage — Hetzner Object Storage (S3-compatible) ──────────────────
#
# REQUIRED for production. If MEDIA_S3_ENDPOINT is empty, the engine silently
# runs in LocalMode (writes to local disk instead of object storage) — this
# is correct for local dev only, never for production.

MEDIA_S3_ENDPOINT=https://your-region.your-objectstorage.com
MEDIA_S3_REGION=eu-central
MEDIA_S3_ACCESS_KEY=your-access-key
MEDIA_S3_SECRET_KEY=your-secret-key
MEDIA_UPLOAD_BUCKET=ics-media-upload
MEDIA_DELIVERY_BUCKET=ics-media-delivery

# Public CDN base URL in front of the delivery bucket.
MEDIA_CDN_BASE_URL=https://cdn.yourdomain.com

# CDN root where MediaMTX writes live HLS segments (live streaming only).
MEDIA_MEDIAMTX_HLS_BASE=https://cdn.yourdomain.com/live

# ── CORS ─────────────────────────────────────────────────────────────────────
#
# Origin allowed to call the upload routes (POST /engine/upload/init,
# PUT/POST /engine/upload/{id}/...) directly from a browser — Learn's
# lesson-authoring page calls these from app.ichebo.org. Every other
# /engine/ route is called server-to-server (Django, MediaMTX) and is
# never wrapped in CORS headers. Default: https://app.ichebo.org
MEDIA_CORS_ALLOWED_ORIGIN=https://app.ichebo.org

# ── Django Callback ────────────────────────────────────────────────────────────
#
# REQUIRED for production. If MEDIA_DJANGO_WEBHOOK_URL is empty, transcode and
# stream-archive webhooks are silently skipped — jobs complete in the engine
# but Django Records never learn about it (status stays "draft" forever).

# Base URL of the Django app — no trailing slash. The engine appends
# /api/media/transcode-complete/ for transcode jobs.
MEDIA_DJANGO_WEBHOOK_URL=https://yourdomain.com

# Shared secret sent as "Authorization: Bearer {key}" on every webhook call.
# MUST exactly match MEDIA_ENGINE_API_KEY in the Django app's .env — there is
# no insecure default on either side; a mismatch causes silent 401s.
MEDIA_DJANGO_API_KEY=generate-a-strong-shared-secret-here
