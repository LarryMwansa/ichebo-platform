# /etc/mediamtx/mediamtx.env
# Copy this file to /etc/mediamtx/mediamtx.env and fill in real values.
# Never commit the real .env file.

DJANGO_WEBHOOK_URL=https://app.ichebo.org
MEDIA_ENGINE_URL=http://localhost:8090
MEDIA_ENGINE_API_KEY=change-me-to-a-long-random-secret
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=ichebo-delivery
S3_ACCESS_KEY=your-hetzner-s3-access-key
S3_SECRET_KEY=your-hetzner-s3-secret-key
CDN_BASE_URL=https://cdn.ichebo.org
