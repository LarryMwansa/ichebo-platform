# ICS Platform — Environment Variables
# Copy to .env and fill in real values before first deployment.
# Never commit the real .env file to version control.

# ── Django Core ────────────────────────────────────────────────────────────────

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated; include domain and www variant
# Example: ics.yourdomain.com,www.ics.yourdomain.com
# app.ichebo.org is the Django app domain (nginx proxies it to gunicorn) —
# ichebo.org/www.ichebo.org is the marketing site, served by nginx directly
# as static files and never reaches Django, but is included here in case any
# server_name overlap or redirect logic ever routes through this app.
ALLOWED_HOSTS=app.ichebo.org,ichebo.org,www.ichebo.org

# Settings module to use
# Local:      ics_project.settings.local
# Production: ics_project.settings.production
DJANGO_SETTINGS_MODULE=ics_project.settings.production

# ── Database ──────────────────────────────────────────────────────────────────

# Use 'sqlite3' for local dev, 'postgresql' for staging/production
DB_ENGINE=postgresql

DB_NAME=ics_db
DB_USER=ics_user
DB_PASSWORD=a-strong-database-password
DB_HOST=localhost
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated; must include scheme (https://). Must include the marketing
# site's domain (ichebo-website) so its waitlist form can POST to /api/waitlist/
# cross-origin — without this, the browser blocks the request even though the
# endpoint itself requires no auth.
# Example: https://ichebo.org,https://www.ichebo.org
CORS_ALLOWED_ORIGINS=https://ichebo.org,https://www.ichebo.org,https://ichebo-website.yourdomain.com

# ── Ichebo Media — Video Engine ─────────────────────────────────────────────────
#
# URL of the Go media engine service (mediad). In production this is the
# internal address of the dedicated video engine server, not localhost.
MEDIA_ENGINE_URL=http://localhost:8090
#
# Shared secret between Django and the Go engine. No insecure default exists —
# this MUST be set explicitly in every environment. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# The same value must be set as MEDIA_DJANGO_API_KEY in the Go engine's
# /etc/ichebo/media.env (see ichebo-media/.env.example).
MEDIA_ENGINE_API_KEY=generate-a-strong-shared-secret-here

# MediaMTX — native RTMP ingest / HLS delivery for live broadcasts scheduled
# via the BroadcastSchedule model (not the YouTube/Vimeo URL-embed path).
# Defaults to placeholder ichebo.org URLs if unset — only matters once
# MediaMTX is actually deployed; set both explicitly at that point.
MEDIAMTX_RTMP_URL=rtmp://media.yourdomain.com/live
MEDIAMTX_HLS_BASE_URL=https://cdn.yourdomain.com/live

# ── VPS Directory Checklist (run once as root before first start) ──────────────
#
#   mkdir -p /var/log/ics /var/log/gunicorn /var/cache/ics
#   chown -R www-data:www-data /var/log/ics /var/log/gunicorn /var/cache/ics
#
# ── Deployment Checklist ──────────────────────────────────────────────────────
#
#   1. Copy this file to .env and fill in real values
#   2. Run: python manage.py migrate
#   3. Run: python manage.py collectstatic --noinput
#   4. Obtain SSL cert: certbot --nginx -d yourdomain.com
#   5. Start Gunicorn: gunicorn ics_project.wsgi:application -c gunicorn.conf.py
#   6. Enable Nginx site and reload: nginx -t && systemctl reload nginx
#   7. Enable Gunicorn systemd service: systemctl enable ics-gunicorn
